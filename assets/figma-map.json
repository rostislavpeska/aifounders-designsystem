  "notes": {
    "iconCount": "55 icons is the TRUE count of <svg> entries in inc/icons.php (the '117' in FIGMA-IMPORT.md counted every array key incl. the type/label registries - doc discrepancy, flagged Session 1)",
    "lazzer": "Lazzer is NOT installed in Figma - display styles (Hero/Title/XL/LG/MD-aig) render Inter (the literal next family in the font-display stack). Upload Lazzer + swap style fontName to fix; weights already correct (Black 900)",
    "lineHeightBinding": "lineHeight variable binding interprets FLOATs as PIXELS (probe 2026-07-07) - leadings are static PERCENT on text styles; brand-diverging heading-sm-leading (AIF 1.2/AIG 1.35) and lead-leading (AIF 1.6/AIG 1.5) carry AIF values, AIG divergence not representable per-mode",
    "buttonLink": ".btn--link + .btn--link.btn--destructive deferred to the Global-link-system session (link idiom, not button anatomy); .smart-btn deferred (support-surface wrapper)",
    "codeConnect": "code_connect deferred: figma plan (Professional; Code Connect needs Org/Enterprise)",
    "iconRootFills": "S2 fix: ALL 55 icon components had opaque white root fills from createNodeFromSvg - cleared to transparent 2026-07-07 (surfaced when the newsletter dark-footer swap showed a white box)",
    "instanceSwapColors": "INSTANCE_SWAP drops per-vector stroke bindings when the swapped icon's structure differs - after swapping an icon inside Button/Badge/Input instances, re-bind the vector strokes to the consuming text role (newsletter variants carry this fix)",
    "typePrimitivesDelta": "48 = 42 manifest + 6 materializations, all real CSS custom properties: heading-md-size (D:28/M:22), heading-sm-size (22/20), lead-size (24/20), benefit-display-size (32/24), _heading-lg-size-aif (36/28) + _heading-lg-size-aig (44/32) hidden per-brand clamp helpers feeding Palette/heading-lg-size",
    "fieldFontSize": "Base/field-font-size + selection-label-size alias TP/size-16 (manifest ref {body-md-size} resolves to size-16)",
    "fontVariables": "font-* STRING values hold the primary family name only (Lazzer/Inter/Space Grotesk/Spline Sans Mono); full CSS stacks live in codeSyntax + tokens.css"
  }
